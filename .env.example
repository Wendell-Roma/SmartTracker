# ─── Database ───────────────────────────────────────────
DATABASE_URL=sqlite:///prices.db

# ─── E-mail (Gmail) ─────────────────────────────────────
EMAIL_SENDER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app   # Use "App Password" do Google
EMAIL_RECEIVER=destino@gmail.com

# ─── Telegram (opcional) ────────────────────────────────
TELEGRAM_TOKEN=seu_bot_token
TELEGRAM_CHAT_ID=seu_chat_id

# ─── Scraper ────────────────────────────────────────────
CHECK_INTERVAL_HOURS=6            # De quanto em quanto tempo verifica
REQUEST_TIMEOUT=15
RETRY_ATTEMPTS=3

# ─── Mercado Livre API ───────────────────────────────────
ML_APP_ID=seu_app_id              # Crie em developers.mercadolivre.com.br
ML_CLIENT_SECRET=seu_secret
